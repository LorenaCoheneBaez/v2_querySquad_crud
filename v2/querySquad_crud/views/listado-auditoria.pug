doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Panel de Auditoría

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

    style.
      .bg-finance { background-color: #1e3a5f; }
      .text-alta { color: #198754; font-weight: bold; }
      .text-mod { color: #0dcaf0; font-weight: bold; }
      .text-baja { color: #dc3545; font-weight: bold; }

  body
    include header

    .container.mt-4
      h2 Auditoría e Historial de Procesos
      hr

      table.table.table-striped.table-bordered.table-hover.mt-3
        thead.table-light
          tr
            th Fecha y Hora
            th Módulo / Entidad
            th Operación
            th Detalle del Movimiento
            th Operador
        tbody
          each log in historial
            tr
              td #{new Date(log.createdAt).toLocaleString('es-AR')}
              td 
                span.badge.bg-secondary #{log.entidad}
              td
                if log.operacion === 'Alta'
                  span.text-alta Alta
                else if log.operacion === 'Baja'
                  span.text-baja Baja
                else
                  span.text-mod #{log.operacion}
              td #{log.detalle}
              td #{log.usuario}

      if historial.length === 0
        p.text-muted No se han registrado movimientos de auditoría en esta sesión.

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026