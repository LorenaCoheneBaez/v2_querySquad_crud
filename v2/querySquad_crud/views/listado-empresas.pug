doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Lista de Empresas

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

    style.
      .bg-finance { background-color: #1e3a5f; }
      .btn-finance { background-color: #1e3a5f; color: white; border: none; }
      .btn-finance:hover { background-color: #16324a; color: white; }

  body
    include header

    .container.mt-4

      // ALERTAS
      if query && query.msg
        .alert.alert-success.alert-dismissible.fade.show(role="alert")
          if query.msg === 'created'
            | Empresa creada correctamente
          else if query.msg === 'updated'
            | Empresa actualizada correctamente
          else if query.msg === 'deleted'
            | Empresa eliminada correctamente
          else if query.msg === 'status'
            | Estado actualizado correctamente

          button.btn-close(type="button", data-bs-dismiss="alert")

      // INDICADORES
      h2 Resumen General
      hr
      if indicadores
        .row.mb-4.g-3 
          .col-md-4
            .card.border-0.shadow-sm.h-100
              .card-body.d-flex.align-items-center
                .text-center.w-100
                  .fs-2.fw-bold.text-primary.mb-2 #{indicadores.empresasActivas}
                  p.text-muted.m-0 Empresas Activas
          .col-md-4
            .card.border-0.shadow-sm.h-100
              .card-body.d-flex.align-items-center
                .text-center.w-100
                  .fs-2.fw-bold.text-info.mb-2 #{indicadores.novedadesActivas}
                  p.text-muted.m-0 Novedades Pendientes
          .col-md-4
            .card.border-0.shadow-sm.h-100
              .card-body.d-flex.align-items-center
                .text-center.w-100
                  .fs-2.fw-bold.mb-2(style="color: #0d6efd;") #{indicadores.cargaOperativaTexto} 
                  p.text-muted.m-0 Carga operativa estimada

      h2 Lista de Empresas
      hr

      .d-flex.justify-content-between.align-items-center.mb-3
        a.btn.btn-finance(href="/empresas/nueva")
          i.bi.bi-plus-lg
          |  Nueva Empresa

        .btn-group
          a.btn.btn-outline-primary(href="/empresas/listado-empresas-activas") Activas
          a.btn.btn-outline-secondary(href="/empresas/listado-empresas-inactivas") Inactivas

      form(method="GET", action="/empresas")
        .input-group.mb-3(style="max-width: 400px;")
          input.form-control(
            type="text",
            name="nombre",
            placeholder="Buscar empresa...",
            value=query && query.nombre ? query.nombre : ''
          )
          button.btn.btn-outline-secondary(type="submit")
            i.bi.bi-search
            |  Buscar

      table.table.table-bordered.table-hover
        thead.table-light
          tr
            th No
            th Cuit
            th Nombre
            th Rubro
            th Detalle de Convenio
            th Estado
            th Acciones

        tbody
          each empresa, index in empresas
            tr
              td #{index + 1}
              td #{empresa.cuit}
              td #{empresa.nombre}
              td #{empresa.rubro}
              
              //Convenios para liquidacion
              td
                if empresa.convenioAplicable && empresa.convenioAplicable.nombre
                  .border.rounded.p-2.bg-light(style="font-size: 0.85em; line-height: 1.2;")
                    strong.d-block.text-dark.mb-1 #{empresa.convenioAplicable.nombre}
                    span.text-muted
                      i.bi.bi-arrow-right-short
                      | Aporte Sindical: 
                      strong #{empresa.convenioAplicable.aporteSindical}% 
                    br
                    span.text-muted
                      i.bi.bi-arrow-right-short
                      | Presentismo: 
                      strong #{empresa.convenioAplicable.adicionalPresentismo}%
                else
                  span.badge.bg-warning.text-dark Sin convenio

              td.align-middle
                if empresa.activo
                  span.badge.bg-success Activo
                else
                  span.badge.bg-secondary Inactivo

              td.align-middle(style="white-space: nowrap;")
                .d-flex.gap-2
                  a.btn.btn-primary.btn-sm(
                    href=`/empresas/${empresa._id}/editar`
                    title="Editar empresa"
                  )
                    i.bi.bi-pencil

                  form(method="POST", action=`/empresas/${empresa._id}/estado`)
                    input(type="hidden", name="_method", value="PUT")
                    button.btn.btn-sm(
                      type="submit",
                      class=empresa.activo ? 'btn-outline-danger' : 'btn-outline-success',
                      title=empresa.activo ? 'Desactivar empresa' : 'Activar empresa'
                    )
                      if empresa.activo
                        i.bi.bi-toggle-off
                      else
                        i.bi.bi-toggle-on

                  form(method="POST", action=`/empresas/${empresa._id}`)
                    input(type="hidden", name="_method", value="DELETE")
                    button.btn.btn-danger.btn-sm(
                      type="button",
                      title="Eliminar empresa",
                      data-bs-toggle="modal"
                      data-bs-target="#confirmarEliminarModal"
                      data-empresa-id=empresa._id
                      data-empresa-nombre=empresa.nombre
                    )
                      i.bi.bi-trash

      if empresas.length === 0
        p.text-muted No hay empresas registradas.

    include modal-eliminar-empresa

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")