doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Nuevo Empleado

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")

    style.
      .bg-finance {
        background-color: #1e3a5f;
      }
      .btn-finance {
        background-color: #1e3a5f;
        color: white;
        border: none;
      }
      .btn-finance:hover {
        background-color: #16324a;
        color: white;
      }

  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-finance
      .container-fluid
        a.navbar-brand(href="/") Query Squad
        .navbar-nav
          a.nav-link(href="/empresas") Empresas
          a.nav-link(href="/empleados") Lista de Empleados
          a.nav-link.active(href="#") Nuevo Empleado

    .container.mt-4
      h2 Registrar Nuevo Empleado
      hr

      a.btn.btn-outline-secondary.mb-3(href="/empleados") ← Volver al listado

      form(action="/empleados" method="POST")

        .row
          .col-md-6.mb-3
            label.form-label Nombre
            input.form-control( type="text" name="nombre" minlength="3"  title="El nombre debe tener al menos 3 caracteres"  required)

          .col-md-6.mb-3
            label.form-label Apellido
            input.form-control( type="text" name="apellido" minlength="3"  title="El apellido debe tener al menos 3 caracteres"  required)

          .col-md-6.mb-3
            label.form-label DNI
            input.form-control(type="text" name="dni" pattern="[0-9]{7,8}" title="El DNI debe tener entre 7 y 8 números sin puntos" minlength="7" maxlength="8" required)

          .col-md-6.mb-3
            label.form-label Empresa
            select.form-select(name="empresa" required)
              option(value="") Selecciona una empresa
              each empresa in empresas
                option(value=empresa._id) #{empresa.nombre}

          .col-md-6.mb-3
            label.form-label Salario
            input.form-control(type="number" name="salario" min="0"  step="any" title="El salario no puede ser negativo" required)


        button.btn.btn-finance.mt-3(type="submit") Crear Empleado

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026