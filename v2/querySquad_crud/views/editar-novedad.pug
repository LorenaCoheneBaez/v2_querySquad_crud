doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Editar Novedad
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
    style.
      .bg-finance { background-color: #1e3a5f; }

  body
    include header

    .container.mt-4
      .d-flex.justify-content-between.align-items-center.mb-3
        h2.mb-0 Editar Novedad de #{novedad.empleadoId.nombre} #{novedad.empleadoId.apellido}
        a.btn.btn-outline-secondary(href="/novedades") Volver

      .card.mb-4
        .card-body
          form(method="POST", action=`/novedades/${novedad._id}`)
            input(type="hidden", name="_method", value="PUT")
            
            .row.g-3
              .col-md-4
                label.form-label Tipo
                select.form-select(name="tipo", id="tipo", required)
                  option(value="Licencia" selected=novedad.tipo==='Licencia') Licencia
                  option(value="Tardanza" selected=novedad.tipo==='Tardanza') Tardanza
                  option(value="Ausencia" selected=novedad.tipo==='Ausencia') Ausencia
                  option(value="Sanción" selected=novedad.tipo==='Sanción') Sanción
                  option(value="Bono" selected=novedad.tipo==='Bono') Bono
                  option(value="Cambio de puesto" selected=novedad.tipo==='Cambio de puesto') Cambio de puesto
                  option(value="Observación" selected=novedad.tipo==='Observación') Observación
                  
              .col-md-4
                label.form-label Estado
                select.form-select(name="estado", required)
                  option(value="pendiente" selected=novedad.estado==='pendiente') Pendiente
                  option(value="procesada" selected=novedad.estado==='procesada') Procesada
                  option(value="rechazada" selected=novedad.estado==='rechazada') Rechazada

              .col-md-4
                label.form-label Fecha
                input.form-control(type="date", name="fecha", required, value=novedad.fecha)

              .col-md-4
                label.form-label Valor de impacto
                input.form-control(type="number", name="valorImpacto", id="valorImpacto", step="0.01", value=novedad.valorImpacto)

              .col-md-12
                label.form-label Descripción
                textarea.form-control(name="descripcion", rows="3", required) #{novedad.descripcion}

              .col-12
                button.btn.btn-primary(type="submit")
                  i.bi.bi-save
                  |  Guardar Cambios

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script.
      const tipoSelect = document.getElementById('tipo');
      const inputValor = document.getElementById('valorImpacto');
      const tiposSinImpacto = ['Observación', 'Cambio de puesto'];

      function actualizarEstadoValorImpacto() {
        const tipoSeleccionado = tipoSelect.value;

        if (tiposSinImpacto.includes(tipoSeleccionado)) {
          inputValor.value = 0;
          inputValor.disabled = true;
          inputValor.required = false;
          inputValor.classList.add('bg-light');
        } else {
          if (inputValor.value == 0 || inputValor.value === '') {
            inputValor.value = '';
          }
          inputValor.disabled = false;
          inputValor.required = true;
          inputValor.classList.remove('bg-light');
        }
      }

      tipoSelect.addEventListener('change', actualizarEstadoValorImpacto);
      actualizarEstadoValorImpacto();