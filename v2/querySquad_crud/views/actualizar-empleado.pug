doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title Actualizar Empleado

    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")

    style.
      .bg-finance {
        background-color: #1e3a5f;
      }
      .btn-finance {
        background-color: #1e3a5f;
        color: white;
        border: none;
      }
      .btn-finance:hover {
        background-color: #16324a;
        color: white;
      }

  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-finance
      .container-fluid
        a.navbar-brand(href="/") Query Squad
        .navbar-nav
          a.nav-link(href="/empleados") Lista de Empleados
          a.nav-link.active(href="#") Actualizar Empleado

    .container.mt-4

      h2 Actualizar Empleado
      hr

      a.btn.btn-outline-secondary.mb-3(href="/empleados") ← Volver al listado

      if empleado

        if error
          .alert.alert-danger #{error}

        if !empresas || empresas.length === 0
          .alert.alert-warning No hay empresas disponibles en el sistema.

        form(method="POST" action=`/empleados/${empleado._id}`)
          input(type="hidden" name="_method" value="PUT")

          .row
            .col-md-6.mb-3
              label.form-label Nombre
              input.form-control(
                type="text",
                name="nombre",
                value=empleado.nombre,
                required
              )

            .col-md-6.mb-3
              label.form-label Apellido
              input.form-control(
                type="text",
                name="apellido",
                value=empleado.apellido,
                required
              )

            .col-md-6.mb-3
              label.form-label DNI
              input.form-control(
                type="text",
                name="dni",
                value=empleado.dni,
                required
              )

            .col-md-6.mb-3
              label.form-label Salario
              input.form-control(
                type="text",
                name="salario",
                value=empleado.salario,
                required
              )

            .col-md-6.mb-3
              label.form-label Empresa Asociada

              if empresas && empresas.length > 0
                select.form-select(name="empresaId" required)
                  option(value="") Selecciona una empresa

                  each empresa in empresas
                    - var currentEmpId = empleado.empresaId && empleado.empresaId._id ? empleado.empresaId._id.toString() : (empleado.empresaId ? empleado.empresaId.toString() : "")
                    option(value=empresa._id, selected=(empresa._id.toString() === currentEmpId))
                      if !empresa.activo
                        | #{empresa.nombre} (Inactiva)
                      else
                        | #{empresa.nombre}

              else
                .text-danger No hay empresas disponibles para asignar.

          button.btn.btn-finance.mt-3(type="submit")
            | Actualizar Empleado

      else if error
        .alert.alert-danger #{error}

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026