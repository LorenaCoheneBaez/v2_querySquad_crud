doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Login

    style.
      body {
        margin: 0;
        font-family: 'Segoe UI', Arial, sans-serif;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #052049, #346fce);
      }

      .card {
        background: #fff;
        padding: 40px 30px;
        border-radius: 16px;
        width: 320px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
      }

      .logo {
        width: 150px;
        margin-bottom: 25px;
      }

      .title {
        font-size: 18px;
        margin-bottom: 25px;
        color: #333;
        font-weight: 600;
      }

      .input {
        width: 100%;
        padding: 12px;
        margin-bottom: 15px;
        border: 1px solid #ccc;
        border-radius: 10px;
        box-sizing: border-box;
      }

      .btn {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(90deg, #0d6efd, #2563eb);
        color: white;
        font-size: 16px;
        cursor: pointer;
        transition: 0.2s ease;
      }

      .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(13,110,253,0.3);
      }

      #loginForm {
        display: none;
        margin-top: 20px;
      }

    script.
      function mostrarLogin() {
        document.getElementById("loginForm").style.display = "block";
        document.getElementById("btnIngresar").style.display = "none";
      }

      window.onload = function () {

        const params = new URLSearchParams(window.location.search);

        if (params.get("error")) {

          alert("Usuario o contraseña incorrectos");

          mostrarLogin();
        }

      }

  body
    .card
      img.logo(src="/img/logo.png", alt="Logo")

      div.title ¡Bienvenidos!

      button#btnIngresar.btn(
        type="button",
        onclick="mostrarLogin()"
      )
        | Ingresar

      form#loginForm(action="/login", method="POST")

        input.input(
          type="text",
          name="usuario",
          placeholder="Usuario",
          required
        )

        input.input(
          type="password",
          name="password",
          placeholder="Contraseña",
          required
        )

        button.btn(type="submit")
          | Entrar