doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Operación Exitosa - Query Squad
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
    style.
      .bg-finance { background-color: #1e3a5f; }
      .message-container { max-width: 500px; margin-top: 100px; }
  
  body.bg-light
    nav.navbar.navbar-dark.bg-finance
      div.container-fluid
        a.navbar-brand(href="/") Query Squad
    
    div.container.message-container.text-center.bg-white.p-5.shadow.rounded
      i.bi.bi-check-circle-fill.text-success(style="font-size: 4rem;")
      h2.h4.mt-3.mb-4 ¡Acción completada!
      p.text-muted= mensaje
      hr
      a.btn.btn-primary(href="/empresas") 
        | Ir al listado de empresas