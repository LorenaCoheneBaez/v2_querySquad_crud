doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Nueva Liquidación

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

    style.
      .bg-finance { background-color: #1e3a5f; }
      .btn-finance { background-color: #1e3a5f; color: white; border: none; }
      .btn-finance:hover { background-color: #16324a; color: white; }

  body
    include header

    .container.mt-4
      h2 Generar Nueva Liquidación
      hr

      a.btn.btn-outline-secondary.mb-3(href="/liquidaciones") ← Volver al listado

      .card.shadow-sm.border-0.mt-2
        .card-body.p-4
          form(action="/liquidaciones" method="POST")
            .row
              .col-md-6.mb-4
                label.form-label.fw-bold Seleccionar Empleado
                select.form-select(name="empleadoId" required)
                  option(value="" disabled selected) -- Seleccione un empleado --
                  if empleados && empleados.length > 0
                    each empleado in empleados
                      option(value=empleado._id) #{empleado.dni} - #{empleado.apellido}, #{empleado.nombre}
                  else
                    option(value="" disabled) No hay empleados registrados o activos

              .col-md-6.mb-4
                label.form-label.fw-bold Período a Liquidar
                input.form-control(
                  type="month"
                  name="periodo"
                  required
                )
                .form-text Seleccione el mes y año (ej. Junio 2026).

            .alert.alert-info.d-flex.align-items-center.mt-2(role="alert")
              i.bi.bi-info-circle-fill.me-3.fs-4
              div
                strong ¡Cálculo Automático!
                br
                | El sistema tomará el salario base del empleado, aplicará las retenciones y adicionales de su Convenio Colectivo, e impactará matemáticamente todas las Novedades que estén marcadas como "procesadas".

            button.btn.btn-finance.w-100.py-2.mt-3(type="submit")
              i.bi.bi-calculator.me-2
              | Generar Liquidación

    footer.text-center.mt-5.mb-3
      small © Query Squad 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")