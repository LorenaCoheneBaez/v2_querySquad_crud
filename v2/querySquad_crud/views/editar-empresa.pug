doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Editar Empresa

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

    style.
      .bg-finance { background-color: #1e3a5f; }
      .btn-finance { background-color: #1e3a5f; color: white; border: none; }
      .btn-finance:hover { background-color: #16324a; color: white; }

  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-finance
      .container-fluid
        a.navbar-brand(href="/") Query Squad
        .navbar-nav
          a.nav-link(href="/empresas") Lista de Empresas
          a.nav-link.active(href="#") Editar Empresa

    .container.mt-4
      h2 Editar Empresa
      hr

      a.btn.btn-outline-secondary.mb-3(href="/empresas") ← Volver al listado

      form(method="POST", action=`/empresas/${empresa._id}`)
        input(type="hidden", name="_method", value="PUT")

        .row
          .col-md-6.mb-3
            label.form-label Nombre
            input.form-control(type="text", name="nombre", value=empresa.nombre, required)

          .col-md-6.mb-3
            label.form-label CUIT
            input.form-control(type="text", name="cuit", value=empresa.cuit, required)

          .col-md-6.mb-3
            label.form-label Rubro
            input.form-control(type="text", name="rubro", value=empresa.rubro, required)

          .col-md-6.mb-3
            label.form-label Email
            input.form-control(type="email", name="emailContacto", value=empresa.emailContacto, required)

          .col-md-6.mb-3
            label.form-label Teléfono
            input.form-control(type="text", name="telefono", value=empresa.telefono, required)

          .col-md-6.mb-3
            label.form-label Dirección
            input.form-control(type="text", name="direccion", value=empresa.direccion, required)

          .col-md-12.mb-3
            label.form-label Persona de contacto
            input.form-control(type="text", name="personaContacto", value=empresa.personaContacto, required)

        hr
        h4.mb-3 Convenio Colectivo de Trabajo (Opcional)

        .row.align-items-end.mb-3.p-3.border.rounded.bg-light
          .col-md-5
            label.form-label Nombre del Convenio
            input.form-control(type="text" name="cctNombre" value=empresa.convenioAplicable ? empresa.convenioAplicable.nombre : '' placeholder="Ej: Empleados de Comercio 130/75")
          .col-md-3
            label.form-label Aporte Sindical (%)
            input.form-control(type="number" step="0.01" name="cctAporte" value=empresa.convenioAplicable ? empresa.convenioAplicable.aporteSindical : '0')
          .col-md-3
            label.form-label Adicional Presentismo (%)
            input.form-control(type="number" step="0.01" name="cctAdicional" value=empresa.convenioAplicable ? empresa.convenioAplicable.adicionalPresentismo : '0')
          .col-md-1.text-end
            button.btn.btn-danger.btn-remove-cct(type="button" title="Eliminar")
              i.bi.bi-trash 

        button.btn.btn-finance.mt-3.w-100(type="submit") Actualizar Empresa

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script.
      document.querySelector('.btn-remove-cct').addEventListener('click', function() {
        document.querySelector('input[name="cctNombre"]').value = '';
        document.querySelector('input[name="cctAporte"]').value = '0';
        document.querySelector('input[name="cctAdicional"]').value = '0';
      });