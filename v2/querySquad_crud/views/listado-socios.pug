doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Listado de Socios

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

    style.
      .bg-finance { background-color: #1e3a5f; }
      .btn-finance { background-color: #1e3a5f; color: white; border: none; }
      .btn-finance:hover { background-color: #16324a; color: white; }

  body
    include header

    .container.mt-4

      //- ALERTAS
      if query && query.msg
        .alert.alert-success.alert-dismissible.fade.show(role="alert")
          if query.msg === 'created'
            | Socio registrado correctamente
          else if query.msg === 'updated'
            | Socio actualizado correctamente
          else if query.msg === 'deleted'
            | Socio dado de baja correctamente
          button.btn-close(type="button", data-bs-dismiss="alert")

      h2 Lista de Socios
      hr

      .d-flex.justify-content-between.align-items-start.mb-3
        a.btn.btn-finance.mt-1(href="/socios/nuevo")
          | Nuevo Socio

        form(method="GET", action="/socios" style="width: 100%; max-width: 400px;")
          .input-group.mb-1
            input.form-control(
              type="text",
              name="dni",
              placeholder="Buscar por DNI...",
              value=query && query.dni ? query.dni : ''
            )
            button.btn.btn-outline-secondary(type="submit")
              i.bi.bi-search
              |  Buscar
          if query && query.dni
            .text-end
              a.text-danger.small(href="/socios" style="text-decoration: none;") Limpiar filtro

      table.table.table-bordered.table-hover
        thead.table-light
          tr
            th Nº
            th Nombre y Apellido
            th DNI
            th Email
            th Participación
            th Permisos
            th Estado
            th Acciones

        tbody
          each socio, index in socios
            tr
              td #{index + 1}
              td #{socio.nombre} #{socio.apellido}
              td #{socio.dni}
              td #{socio.email}
              td #{socio.participacion}%
              
              td 
                if socio.permisos && socio.permisos.length > 0
                  small.text-muted #{socio.permisos.join(', ')}
                else
                  small.text-danger Sin permisos

              td.align-middle
                if socio.activo
                  span.badge.bg-success Activo
                else
                  span.badge.bg-secondary Inactivo

              td(style="white-space: nowrap;")
                .d-flex.gap-2
                  a.btn.btn-primary.btn-sm(
                    href=`/socios/actualizar/${socio._id}`,
                    title="Editar socio"
                  )
                    i.bi.bi-pencil

                  button.btn.btn-danger.btn-sm(
                    type="button",
                    title="Dar de baja",
                    data-bs-toggle="modal",
                    data-bs-target="#modalEliminarSocio",
                    data-id=socio._id,
                    data-nombre=`${socio.nombre} ${socio.apellido}`
                  )
                    i.bi.bi-trash

      if !socios || socios.length === 0
        if query && query.dni
          .alert.alert-warning.mt-4
            i.bi.bi-search.me-2
            | No se encontraron socios con el DNI ingresado.
        else
          p.text-muted No hay socios registrados.

    //Modal eliminar (baja lógica)
    .modal.fade#modalEliminarSocio(tabindex="-1" aria-hidden="true")
      .modal-dialog.modal-dialog-centered
        .modal-content
          .modal-header.bg-danger.text-white
            h5.modal-title Confirmar Baja
            button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
          .modal-body
            p ¿Está seguro que desea dar de baja al socio <strong id="modalSocioTexto"></strong>?
            p.text-muted.small Esta acción es una baja lógica; el socio quedará inactivo en el sistema.
          .modal-footer
            button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
            form#formEliminarSocio(method="POST" action="")
              input(type="hidden" name="_method" value="DELETE")
              button.btn.btn-danger(type="submit") Sí, dar de baja

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script.
      // Modal eliminar
      const modalEliminar = document.getElementById('modalEliminarSocio');
      if (modalEliminar) {
        modalEliminar.addEventListener('show.bs.modal', function (event) {
          const button = event.relatedTarget;
          
          const id = button.getAttribute('data-id');
          const nombre = button.getAttribute('data-nombre');
          
          document.getElementById('modalSocioTexto').textContent = nombre;
          
          const form = document.getElementById('formEliminarSocio');
          form.action = `/socios/${id}`;
        });
      }