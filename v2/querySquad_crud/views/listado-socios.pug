doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Listado de Socios

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

    style.
      .bg-finance {
        background-color: #1e3a5f;
      }
      .btn-finance {
        background-color: #1e3a5f;
        color: white;
        border: none;
      }
      .btn-finance:hover {
        background-color: #16324a;
        color: white;
      }

  body
    include header

    .container.mt-4

      if query && query.msg
        .alert.alert-success.alert-dismissible.fade.show(role="alert")
          if query.msg === 'created'
            | Socio registrado correctamente
          else if query.msg === 'updated'
            | Socio actualizado correctamente
          else if query.msg === 'deleted'
            | Socio eliminado correctamente

          button.btn-close(type="button", data-bs-dismiss="alert")

      h2 Lista de Socios
      hr

      .d-flex.justify-content-between.align-items-center.mb-3
        a.btn.btn-finance(href="/socios/nuevo")
          | Nuevo Socio

        form(method="GET", action="/socios")
          .input-group.mb-3(style="max-width: 400px;")
            input.form-control(
              type="text",
              name="dni",
              placeholder="Buscar por DNI...",
              value=query && query.dni ? query.dni : ''
            )
            button.btn.btn-outline-secondary(type="submit")
              i.bi.bi-search
              |  Buscar

      table.table.table-bordered.table-hover
        thead.table-light
          tr
            th Nº
            th Nombre y Apellido
            th DNI
            th Email
            th Participación
            th Permisos
            th Acciones

        tbody
          each socio, index in socios
            tr
              td #{index + 1}
              td #{socio.nombre} #{socio.apellido}
              td #{socio.dni}
              td #{socio.email}
              td #{socio.participacion}%
              
              td 
                if socio.permisos && socio.permisos.length > 0
                  //- Mostramos los permisos separados por coma
                  small.text-muted #{socio.permisos.join(', ')}
                else
                  small.text-danger Sin permisos

              td(style="white-space: nowrap;")
                .d-flex.gap-2

                  a.btn.btn-primary.btn-sm(
                    href=`/socios/actualizar/${socio._id}`,
                    title="Editar socio"
                  )
                    i.bi.bi-pencil

                  form(
                    method="POST",
                    action=`/socios/${socio._id}`
                  )
                    input(
                      type="hidden",
                      name="_method",
                      value="DELETE"
                    )

                    button.btn.btn-danger.btn-sm(
                      type="submit",
                      title="Eliminar socio"
                    )
                      i.bi.bi-trash

      if !socios || socios.length === 0
        p.text-muted No hay socios registrados.

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")