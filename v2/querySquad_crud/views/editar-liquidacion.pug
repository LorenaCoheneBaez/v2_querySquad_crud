doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Editar Liquidación

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

    style.
      .bg-finance { background-color: #1e3a5f; }
      .btn-finance { background-color: #1e3a5f; color: white; border: none; }
      .btn-finance:hover { background-color: #16324a; color: white; }

  body
    include header

    .container.mt-4
      h2 Editar Liquidación
      hr

      a.btn.btn-outline-secondary.mb-3(href="/liquidaciones") ← Volver al listado

      .card.shadow-sm.border-0.mt-2
        .card-body.p-4
          form(method="POST", action=`/liquidaciones/${liquidacion._id}`)
            input(type="hidden", name="_method", value="PUT")

            //- Datos de solo lectura
            .row.mb-4
              .col-md-4
                label.form-label Empleado
                input.form-control(type="text", value=`${liquidacion.empleadoId.apellido}, ${liquidacion.empleadoId.nombre}`, disabled)
              .col-md-4
                label.form-label Empresa
                input.form-control(type="text", value=liquidacion.empresaId.nombre, disabled)
              .col-md-4
                label.form-label Período
                input.form-control(type="text", value=liquidacion.periodo, disabled)

            hr.mb-4
            h5.mb-3 Ajuste de Valores y estado

            //- Datos editables
            .row.mb-3
              .col-md-6
                label.form-label(for="montoLiquidado") Monto Final Liquidado ($)
                input.form-control.border-primary(
                  type="number", 
                  step="0.01", 
                  name="montoLiquidado", 
                  id="montoLiquidado",
                  value=liquidacion.montoLiquidado, 
                  required
                )
                small.text-muted Si modifica este valor, perderá la coincidencia exacta con el recibo.
              
              .col-md-4.mb-3
                label.form-label(for="activo") Estado de la Liquidación
                select.form-select(name="activo" id="activo" required)
                  option(value="true" selected=liquidacion.activo===true) Activa
                  option(value="false" selected=liquidacion.activo===false) Desactivada (Inactiva)
              
              .col-md-4.mb-3
                label.form-label(for="observaciones") Observaciones (Opcional)
                input.form-control(
                  type="text", 
                  name="observaciones", 
                  id="observaciones",
                  value=liquidacion.observaciones || ''
                )

            button.btn.btn-finance.w-100.py-2.mt-3(type="submit")
              i.bi.bi-save.me-2
              | Guardar Cambios

    footer.text-center.mt-5.mb-3
      small © Query Squad 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")