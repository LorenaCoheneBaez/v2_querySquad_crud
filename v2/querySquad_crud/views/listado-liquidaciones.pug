doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Listado de Liquidaciones

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

    style.
      .bg-finance { background-color: #1e3a5f; }
      .btn-finance { background-color: #1e3a5f; color: white; border: none; }
      .btn-finance:hover { background-color: #16324a; color: white; }
      
      @media print {
        body * { visibility: hidden; }
        .modal.show .modal-content, .modal.show .modal-content * { visibility: visible; }
        .modal.show .modal-content { 
          position: absolute; 
          left: 0; 
          top: 0; 
          width: 100%; 
          border: none; 
          box-shadow: none; 
        }
        .no-print { display: none !important; }
      }

  body
    include header

    .container.mt-4

      //- ALERTAS
      if query && query.msg
        .alert.alert-success.alert-dismissible.fade.show(role="alert")
          if query.msg === 'created'
            | Liquidación generada correctamente
          else if query.msg === 'updated'
            | Liquidación actualizada correctamente
          else if query.msg === 'deleted'
            | Liquidación dada de baja correctamente
          button.btn-close(type="button", data-bs-dismiss="alert")

      h2 Lista de Liquidaciones
      hr

      .d-flex.justify-content-between.align-items-start.mb-3
        a.btn.btn-finance.mt-1(href="/liquidaciones/nueva")
          | Nueva Liquidación

        form(method="GET", action="/liquidaciones" style="width: 100%; max-width: 700px;")
          .row.g-2.align-items-center
            .col-md-3
              input.form-control(
                type="text",
                name="periodo",
                placeholder="Período (ej: 2026-06)",
                value=query && query.periodo ? query.periodo : ''
              )
            .col-md-3
              input.form-control(
                type="text",
                name="dni",
                placeholder="DNI Empleado",
                value=query && query.dni ? query.dni : ''
              )
            .col-md-4
              input.form-control(
                type="text",
                name="empresa",
                placeholder="Nombre Empresa",
                value=query && query.empresa ? query.empresa : ''
              )
            .col-md-2
              button.btn.btn-outline-secondary.w-100(type="submit")
                i.bi.bi-search
                |  Buscar
              
              if query && (query.periodo || query.dni || query.empresa)
                a.btn.btn-link.btn-sm.w-100.p-0.mt-1.text-danger(href="/liquidaciones" style="text-decoration: none;") 
                  | Limpiar filtros

      table.table.table-bordered.table-hover
        thead.table-light
          tr
            th Nº
            th Empleado
            th Empresa
            th Período
            th Salario Base
            th Monto Liquidado
            th Estado
            th Acciones

        tbody
          each liquidacion, index in liquidaciones
            tr
              td #{index + 1}
              td #{liquidacion.empleadoId.nombre} #{liquidacion.empleadoId.apellido}
              td #{liquidacion.empresaId.nombre}
              td #{liquidacion.periodo}
              td $#{liquidacion.salarioBase.toFixed(2)}
              td $#{liquidacion.montoLiquidado.toFixed(2)}

              td.align-middle
                if liquidacion.activo
                  span.badge.bg-success Activa
                else
                  span.badge.bg-secondary Desactivada

              td(style="white-space: nowrap;")
                .d-flex.gap-2
                  button.btn.btn-info.btn-sm.text-white(
                    type="button",
                    title="Ver detalle / recibo",
                    data-bs-toggle="modal",
                    data-bs-target=`#modalRecibo-${liquidacion._id}`
                  )
                    i.bi.bi-file-earmark-text

                  a.btn.btn-primary.btn-sm(
                    href=`/liquidaciones/actualizar/${liquidacion._id}`,
                    title="Editar liquidación"
                  )
                    i.bi.bi-pencil

                  button.btn.btn-danger.btn-sm(
                    type="button",
                    title="Dar de baja",
                    data-bs-toggle="modal",
                    data-bs-target="#modalEliminarLiquidacion",
                    data-id=liquidacion._id,
                    data-empleado=`${liquidacion.empleadoId.apellido}, ${liquidacion.empleadoId.nombre}`,
                    data-periodo=liquidacion.periodo
                  )
                    i.bi.bi-trash

      if liquidaciones.length === 0
        if query && (query.periodo || query.dni || query.empresa)
          .alert.alert-warning.mt-4.d-flex.align-items-center
            i.bi.bi-search.fs-3.me-3
            div
              h5.alert-heading.mb-1 Sin resultados
              p.mb-0 No se encontraron liquidaciones que coincidan con los filtros ingresados.
        else
          p.text-muted.mt-4 No hay liquidaciones registradas en el sistema.

    //modal detalle
    each liquidacion in liquidaciones
      .modal.fade(id=`modalRecibo-${liquidacion._id}` tabindex="-1" aria-hidden="true")
        .modal-dialog.modal-lg.modal-dialog-centered
          .modal-content
            .modal-header.bg-finance.text-white.no-print
              h5.modal-title Detalle de Liquidación
              button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
            
            .modal-body.p-4
              .border.p-3.mb-3
                .row
                  .col-8
                    h5.mb-1.text-uppercase #{liquidacion.empresaId.nombre}
                    small.d-block Dirección: #{liquidacion.empresaId.direccion}
                  .col-4.text-end
                    strong CUIT: 
                    span #{liquidacion.empresaId.cuit}
              
              .border.p-3.mb-3
                .row
                  .col-6
                    strong Empleado: 
                    span #{liquidacion.empleadoId.apellido}, #{liquidacion.empleadoId.nombre}
                    br
                    strong DNI: 
                    span #{liquidacion.empleadoId.dni}
                  .col-6.text-end
                    h5.m-0 RECIBO DE HABERES
                    strong Período: 
                    span.fs-5 #{liquidacion.periodo}

              // Detalles
              table.table.table-bordered.mt-4
                thead.table-light
                  tr
                    th Concepto
                    th.text-end Remunerativo
                    th.text-end Deducciones
                tbody
                  tr
                    td Sueldo Básico
                    td.text-end $ #{liquidacion.salarioBase.toFixed(2)}
                    td.text-end
                  
                  if liquidacion.empresaId.convenioAplicable && liquidacion.empresaId.convenioAplicable.nombre
                    if liquidacion.desglose && liquidacion.desglose.premioPresentismo > 0
                      tr
                        td Adicional Presentismo (#{liquidacion.empresaId.convenioAplicable.adicionalPresentismo}%)
                        td.text-end $ #{liquidacion.desglose.premioPresentismo.toFixed(2)}
                        td.text-end
                    if liquidacion.desglose && liquidacion.desglose.deduccionSindical > 0
                      tr
                        td Aporte Sindical - #{liquidacion.empresaId.convenioAplicable.nombre} (#{liquidacion.empresaId.convenioAplicable.aporteSindical}%)
                        td.text-end
                        td.text-end $ #{liquidacion.desglose.deduccionSindical.toFixed(2)}

                  if liquidacion.novedadesAplicadas && liquidacion.novedadesAplicadas.length > 0
                    each novedad in liquidacion.novedadesAplicadas
                      tr
                        td #{novedad.tipo} (#{novedad.descripcion})
                        if novedad.tipoImpacto === 'suma'
                          td.text-end $ #{novedad.valorImpacto.toFixed(2)}
                          td.text-end
                        else if novedad.tipoImpacto === 'resta'
                          td.text-end
                          td.text-end $ #{novedad.valorImpacto.toFixed(2)}
                
                tfoot
                  tr
                    th.text-end NETO A COBRAR
                    th.text-center(colspan="2").fs-5 $ #{liquidacion.montoLiquidado.toFixed(2)}

              .row.mt-5.pt-4
                .col-6.text-center
                  hr(style="width: 80%; margin: 0 auto;")
                  small Firma del Empleador
                .col-6.text-center
                  hr(style="width: 80%; margin: 0 auto;")
                  small Firma del Empleado (Conformidad)
            
            .modal-footer.no-print
              button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cerrar
              button.btn.btn-primary(type="button" onclick="window.print()")
                i.bi.bi-printer 
                |  Imprimir / PDF

    //Modal eliminar
    .modal.fade#modalEliminarLiquidacion(tabindex="-1" aria-hidden="true")
      .modal-dialog.modal-dialog-centered
        .modal-content
          .modal-header.bg-danger.text-white
            h5.modal-title Confirmar Baja
            button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
          .modal-body
            p ¿Está seguro que desea dar de baja la liquidación del período <strong id="modalPeriodoTexto"></strong> para el empleado <strong id="modalEmpleadoTexto"></strong>?
            p.text-muted.small Esta acción es una baja lógica; el registro permanecerá en el sistema como inactivo.
          .modal-footer
            button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
            form#formEliminarLiquidacion(method="POST" action="")
              input(type="hidden" name="_method" value="DELETE")
              button.btn.btn-danger(type="submit") Sí, dar de baja

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    
    //Modal eliminacion
    script.
      const modalEliminar = document.getElementById('modalEliminarLiquidacion');
      if (modalEliminar) {
        modalEliminar.addEventListener('show.bs.modal', function (event) {
          const button = event.relatedTarget;
          
          const id = button.getAttribute('data-id');
          const empleado = button.getAttribute('data-empleado');
          const periodo = button.getAttribute('data-periodo');
          
          document.getElementById('modalEmpleadoTexto').textContent = empleado;
          document.getElementById('modalPeriodoTexto').textContent = periodo;
          
          const form = document.getElementById('formEliminarLiquidacion');
          form.action = `/liquidaciones/${id}`;
        });
      }
