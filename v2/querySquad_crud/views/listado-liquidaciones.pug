doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Listado de Liquidaciones

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

    style.
      .bg-finance {
        background-color: #1e3a5f;
      }
      .btn-finance {
        background-color: #1e3a5f;
        color: white;
        border: none;
      }
      .btn-finance:hover {
        background-color: #16324a;
        color: white;
      }

  body
    include header

    .container.mt-4

      if query && query.msg
        .alert.alert-success.alert-dismissible.fade.show(role="alert")
          if query.msg === 'created'
            | Liquidación generada correctamente
          else if query.msg === 'updated'
            | Liquidación actualizada correctamente
          else if query.msg === 'deleted'
            | Liquidación eliminada correctamente

          button.btn-close(type="button", data-bs-dismiss="alert")

      h2 Lista de Liquidaciones
      hr

      .d-flex.justify-content-between.align-items-center.mb-3
        a.btn.btn-finance(href="/liquidaciones/nueva")
          | Nueva Liquidación

        form(method="GET", action="/liquidaciones")
          .input-group.mb-3(style="max-width: 400px;")
            input.form-control(
              type="text",
              name="periodo",
              placeholder="Buscar por período (2026-06)...",
              value=query && query.periodo ? query.periodo : ''
            )
            button.btn.btn-outline-secondary(type="submit")
              i.bi.bi-search
              |  Buscar

      table.table.table-bordered.table-hover
        thead.table-light
          tr
            th Nº
            th Empleado
            th Empresa
            th Período
            th Salario Base
            th Monto Liquidado
            th Acciones

        tbody
          each liquidacion, index in liquidaciones
            tr
              td #{index + 1}
              td #{liquidacion.empleadoId.nombre} #{liquidacion.empleadoId.apellido}
              td #{liquidacion.empresaId.nombre}
              td #{liquidacion.periodo}
              td $#{liquidacion.salarioBase.toFixed(2)}
              td $#{liquidacion.montoLiquidado.toFixed(2)}

              td(style="white-space: nowrap;")
                .d-flex.gap-2

                  a.btn.btn-primary.btn-sm(
                    href=`/liquidaciones/actualizar/${liquidacion._id}`,
                    title="Editar liquidación"
                  )
                    i.bi.bi-pencil

                  form(
                    method="POST",
                    action=`/liquidaciones/${liquidacion._id}`
                  )
                    input(
                      type="hidden",
                      name="_method",
                      value="DELETE"
                    )

                    button.btn.btn-danger.btn-sm(
                      type="submit",
                      title="Eliminar liquidación"
                    )
                      i.bi.bi-trash

      if liquidaciones.length === 0
        p.text-muted No hay liquidaciones registradas.

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
