doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Error - Query Squad
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    style.
      .bg-finance { background-color: #1e3a5f; }
      .error-container { max-width: 500px; margin-top: 100px; }
  
  body.bg-light
    nav.navbar.navbar-dark.bg-finance
      div.container-fluid
        a.navbar-brand(href="/") Query Squad
    
    div.container.error-container.text-center.bg-white.p-5.shadow.rounded
      h1.display-1.text-danger 404
      h2.h4.mb-4 Ups! Algo salió mal
      p.text-muted= mensaje
      hr
      a.btn.btn-primary(href="javascript:history.back()") 
        i.bi.bi-arrow-left 
        |  Volver e intentar de nuevo