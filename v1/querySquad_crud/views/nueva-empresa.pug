doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Nueva Empresa

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")

    style.
      .bg-finance {
        background-color: #1e3a5f;
      }
      .btn-finance {
        background-color: #1e3a5f;
        color: white;
        border: none;
      }
      .btn-finance:hover {
        background-color: #16324a;
        color: white;
      }

  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-finance
      .container-fluid
        a.navbar-brand(href="/") Query Squad
        .navbar-nav
          a.nav-link(href="/empresas") Lista de Empresas
          a.nav-link.active(href="#") Nueva Empresa

    .container.mt-4
      h2 Registrar Nueva Empresa
      hr

      a.btn.btn-outline-secondary.mb-3(href="/empresas") ← Volver al listado

      form(action="/empresas" method="POST")
        
        .row
          .col-md-6.mb-3
            label.form-label Nombre de la Empresa
            input.form-control(type="text" name="nombre" minlength="3" maxlength="100" title="El nombre debe tener entre 3 y 100 caracteres"  required)

          .col-md-6.mb-3
            label.form-label CUIT
            input.form-control(type="text" name="cuit" pattern="[0-9]{2}-[0-9]{8}-[0-9]{1}"  title="El formato del CUIT debe ser exacto: XX-XXXXXXXX-X (ejemplo: 30-12345678-9)"  placeholder="XX-XXXXXXXX-X" required)

          .col-md-6.mb-3
            label.form-label Rubro
            input.form-control(type="text" name="rubro" required)

          .col-md-6.mb-3
            label.form-label Email de Contacto
            input.form-control(type="email" name="emailContacto" title="Debe ser un correo electrónico válido" required)

          .col-md-6.mb-3
            label.form-label Teléfono
            input.form-control(type="text" name="telefono" pattern="[0-9+\\-\\s]+" title="El teléfono solo puede contener números, espacios, guiones o el signo +" required)

          .col-md-6.mb-3
            label.form-label Dirección
            input.form-control(type="text" name="direccion" required)

          .col-md-6.mb-3
            label.form-label Persona de Contacto
            input.form-control(type="text" name="personaContacto" required)

        button.btn.btn-finance.mt-3(type="submit") Crear Empresa

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026