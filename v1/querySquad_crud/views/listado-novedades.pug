doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Listado de Novedades
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
    style.
      .bg-finance { background-color: #1e3a5f; }

  body
    include header

    .container.mt-4
      if query && query.msg === 'created'
        .alert.alert-success.alert-dismissible.fade.show(role="alert")
          | Novedad creada correctamente
          button.btn-close(type="button", data-bs-dismiss="alert")

      .d-flex.justify-content-between.align-items-center.mb-3
        h2.mb-0 Novedades

      .card.mb-4
        .card-body
          h5.card-title.mb-3 Registrar nueva novedad
          form(method="POST", action="/novedades")
            .row.g-3
              .col-md-5
                label.form-label(for="empleadoId") Empleado
                select.form-select(name="empleadoId", id="empleadoId", required)
                  if empleados.length === 0
                    option(value="") No hay empleados habilitados o con empresas activas
                  else
                    option(value="") Seleccionar empleado...
                    each empleado in empleados
                      option(value=empleado._id) #{empleado._id.toString().slice(-5).toUpperCase()} — #{empleado.nombre} #{empleado.apellido} — #{empleado.empresaNombre}

              .col-md-3
                label.form-label(for="tipo") Tipo
                select.form-select(name="tipo", id="tipo", required)
                  option(value="") Seleccionar tipo...
                  option(value="Licencia") Licencia
                  option(value="Tardanza") Tardanza
                  option(value="Ausencia") Ausencia
                  option(value="Sanción") Sanción
                  option(value="Cambio de puesto") Cambio de puesto
                  option(value="Observación") Observación
  
              .col-md-2
                label.form-label(for="estado") Estado
                select.form-select(name="estado", id="estadoNueva", required)
                  option(value="pendiente") Pendiente
                  option(value="procesada") Procesada
                  option(value="rechazada") Rechazada

              .col-md-4
                label.form-label(for="fecha") Fecha
                input.form-control(type="date", name="fecha", id="fecha", required)

              .col-md-12
                label.form-label(for="descripcion") Descripción
                textarea.form-control(name="descripcion", id="descripcion", rows="3", required)

              .col-12
                button.btn.btn-primary(type="submit")
                  i.bi.bi-plus-lg
                  |  Agregar novedad

      .card.mb-4.bg-light
        .card-body.py-2
          form.row.g-2.align-items-center(method="GET" action="/novedades")
            .col-auto
              strong Filtrar:
            .col-auto
              select.form-select.form-select-sm(name="estadoActivo")
                option(value="") Solo Activas
                option(value="inactivas" selected=query.estadoActivo=='inactivas') Solo Borradas (Inactivas)
                option(value="todas" selected=query.estadoActivo=='todas') Todas (Historial completo)
            .col-auto
              select.form-select.form-select-sm(name="estado")
                option(value="") Todos los estados
                option(value="pendiente" selected=query.estado=='pendiente') Pendiente
                option(value="procesada" selected=query.estado=='procesada') Procesada
                option(value="rechazada" selected=query.estado=='rechazada') Rechazada
            .col-auto
              select.form-select.form-select-sm(name="empresaId")
                option(value="") Todas las empresas
                each empresa in empresas
                  option(value=empresa._id.toString() selected=query.empresaId==empresa._id.toString())= empresa.nombre
            .col-auto
              button.btn.btn-sm.btn-secondary(type="submit") Aplicar Filtro
              a.btn.btn-sm.btn-outline-secondary.ms-2(href="/novedades") Limpiar

      .d-flex.justify-content-between.align-items-center.mb-3
        h5.mb-3 Listado de Novedades

      table.table.table-bordered.table-hover
        thead.table-light
          tr
            th ID
            th Empleado
            th Empresa
            th Tipo
            th Descripción
            th Fecha
            th Estado
            th Acciones
        tbody
          each novedad in novedades
            tr
              td #{novedad._id.toString().slice(-5).toUpperCase()}
              td #{novedad.empleadoId.nombre} #{novedad.empleadoId.apellido}
              td #{novedad.empleadoId.empresaId ? novedad.empleadoId.empresaId.nombre : 'Sin empresa'}
              td #{novedad.tipo}
              td #{novedad.descripcion}
              td #{novedad.fecha}
              td
                if novedad.estado === 'procesada'
                  span.badge.bg-success Procesada
                else if novedad.estado === 'rechazada'
                  span.badge.bg-danger Rechazada
                else
                  span.badge.bg-warning.text-dark Pendiente
              td
                .d-flex.gap-2
                  if novedad.activo
                    a.btn.btn-sm.btn-outline-primary(href=`/novedades/editar/${novedad._id}`)
                      i.bi.bi-pencil
                    button.btn.btn-sm.btn-outline-danger(type="button", data-bs-toggle="modal", data-bs-target="#confirmarEliminarNovedadModal", data-novedad-id=novedad._id, data-novedad-tipo=novedad.tipo, data-empleado-nombre=`${novedad.empleadoId.nombre} ${novedad.empleadoId.apellido}`)
                      i.bi.bi-trash
                  else
                    span.badge.bg-secondary Borrada

      if novedades.length === 0
        p.text-muted No hay novedades registradas.

    include modal-eliminar-novedad

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")