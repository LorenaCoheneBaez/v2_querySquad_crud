doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Editar Empresa

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")

    style.
      .bg-finance {
        background-color: #1e3a5f;
      }
      .btn-finance {
        background-color: #1e3a5f;
        color: white;
        border: none;
      }
      .btn-finance:hover {
        background-color: #16324a;
        color: white;
      }

  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-finance
      .container-fluid
        a.navbar-brand(href="/") Query Squad
        .navbar-nav
          a.nav-link(href="/empresas") Lista de Empresas
          a.nav-link.active(href="#") Editar Empresa

    .container.mt-4
      h2 Editar Empresa
      hr

      a.btn.btn-outline-secondary.mb-3(href="/empresas") ← Volver al listado

      form(method="POST", action=`/empresas/${empresa._id}`)
        input(type="hidden", name="_method", value="PUT")

        .row
          .col-md-6.mb-3
            label.form-label Nombre
            input.form-control(type="text", name="nombre", value=empresa.nombre, required)

          .col-md-6.mb-3
            label.form-label CUIT
            input.form-control(type="text", name="cuit", value=empresa.cuit, required)

          .col-md-6.mb-3
            label.form-label Rubro
            input.form-control(type="text", name="rubro", value=empresa.rubro, required)

          .col-md-6.mb-3
            label.form-label Email
            input.form-control(type="email", name="emailContacto", value=empresa.emailContacto, required)

          .col-md-6.mb-3
            label.form-label Teléfono
            input.form-control(type="text", name="telefono", value=empresa.telefono, required)

          .col-md-6.mb-3
            label.form-label Dirección
            input.form-control(type="text", name="direccion", value=empresa.direccion, required)

          .col-md-6.mb-3
            label.form-label Persona de contacto
            input.form-control(type="text", name="personaContacto", value=empresa.personaContacto, required)

        button.btn.btn-finance.mt-3(type="submit") Actualizar Empresa

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026