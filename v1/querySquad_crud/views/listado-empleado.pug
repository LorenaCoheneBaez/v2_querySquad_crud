doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Listado de Empleados

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

    style.
      .bg-finance {
        background-color: #1e3a5f;
      }
      .btn-finance {
        background-color: #1e3a5f;
        color: white;
        border: none;
      }
      .btn-finance:hover {
        background-color: #16324a;
        color: white;
      }

  body
    include header

    .container.mt-4

      if query && query.msg
        .alert.alert-success.alert-dismissible.fade.show(role="alert")
          if query.msg === 'created'
            | Empleado creado correctamente
          else if query.msg === 'updated'
            | Empleado actualizado correctamente
          else if query.msg === 'deleted'
            | Empleado eliminado correctamente

          button.btn-close(type="button", data-bs-dismiss="alert")

      h2 Lista de Empleados
      hr

      .d-flex.justify-content-between.align-items-center.mb-3
        a.btn.btn-finance(href="/empleados/nuevo")
          | Nuevo Empleado

        form(method="GET", action="/empleados")
          .input-group.mb-3(style="max-width: 400px;")
            input.form-control(
              type="text",
              name="nombre",
              placeholder="Buscar empleado...",
              value=query && query.nombre ? query.nombre : ''
            )
            button.btn.btn-outline-secondary(type="submit")
              i.bi.bi-search
              |  Buscar

      table.table.table-bordered.table-hover
        thead.table-light
          tr
            th No
            th Nombre
            th DNI
            th Empresa
            th Salario
            th Acciones

        tbody
          each empleado, index in empleados
            tr
              td #{index + 1}
              td #{empleado.nombre} #{empleado.apellido}
              td #{empleado.dni}
              td 
                | #{empleado.nombreEmpresa}
                if empleado.empresaActiva === false
                  span.badge.bg-danger.ms-2 Inactiva
              td $#{empleado.salario.toFixed(2)}

              td(style="white-space: nowrap;")
                .d-flex.gap-2
                  a.btn.btn-primary.btn-sm(
                    href=`/empleados/actualizar/${empleado._id}`,
                    title="Editar empleado"
                  )
                    i.bi.bi-pencil

                  form(method="POST", action=`/empleados/${empleado._id}`)
                    input(type="hidden", name="_method", value="DELETE")
                    button.btn.btn-danger.btn-sm(
                      type="button",
                      title="Eliminar empleado",
                      data-bs-toggle="modal",
                      data-bs-target="#confirmarEliminarEmpleadoModal",
                      data-empleado-id=empleado._id,
                      data-empleado-nombre=empleado.nombre,
                      data-empleado-apellido=empleado.apellido
                    )
                      i.bi.bi-trash

      if empleados.length === 0
        p.text-muted No hay empleados registrados

    include modal-eliminar-empleado

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")